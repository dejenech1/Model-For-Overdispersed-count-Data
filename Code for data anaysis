 get_pearson <- function(model){
   sum(residuals(model, type="pearson")^2) / model$df.residual
 }
 
 data.frame(
   Model = c("Poisson", "Quasi-Poisson", "NegBin", "GAM"),
   Pearson_ratio = c(
     get_pearson(pois_model),
     get_pearson(qp_model),
     get_pearson(nb_model),
     get_pearson(fql_model)
   )
 ) 
 
 
 
 
